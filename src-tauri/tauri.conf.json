{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Recall",
  "version": "1.0.11",
  "identifier": "dev.madlezz.recall",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Recall",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:; connect-src 'self' ipc: https://ipc.localhost asset: https://asset.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "app", "appimage", "dmg"],
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:recall.db"]
    },
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$APPDATA/images/**"],
        "deny": []
      }
    },
    "updater": {
      "pubkey": "WOeuI3Gf9rvc9cu818ZaPFP35MvsvH3bole18iYHbfM=",
      "endpoints": [
        "https://github.com/Madlezz/Recall/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
